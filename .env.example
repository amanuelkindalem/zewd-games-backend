# ── SERVER ──
PORT=5000
NODE_ENV=development

# ── DATABASE ──
# Local MongoDB:
MONGO_URI=mongodb://127.0.0.1:27017/zewd_games
# Or MongoDB Atlas (cloud, free tier):
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/zewd_games

# ── CORS — your React frontend URL(s), comma separated ──
CLIENT_URLS=http://localhost:3000,https://your-app.csb.app

# ── EMAIL NOTIFICATIONS (Nodemailer via Gmail SMTP example) ──
# Use a Gmail App Password, not your normal password:
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_16_char_app_password
NOTIFY_EMAIL=info@zewdgames.com

# ── ADMIN ──
# Simple shared-secret for admin endpoints (leads list, etc.)
ADMIN_API_KEY=change_this_to_a_long_random_string

# ── RATE LIMITING ──
RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_MAX=100
